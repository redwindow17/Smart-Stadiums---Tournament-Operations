# Copy this file to .env (or export the variables) before running.
# Every variable is OPTIONAL - the app runs fully offline without any of them.

# Enables the Claude-powered assistant. Without it, StadiumIQ runs in
# deterministic offline demo mode (every feature still works).
ANTHROPIC_API_KEY=

# Model used when the key is set.
STADIUMIQ_MODEL=claude-opus-4-8

# Requests per minute allowed per client IP on the chat endpoint.
STADIUMIQ_RATE_LIMIT=30

# Maximum accepted length (characters) of a single chat message.
STADIUMIQ_MAX_MESSAGE_LENGTH=1000
